datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model SavedConfig {
  id        String   @id @default(uuid())
  name      String
  sessionId String   // to tie config to a user/browser session
  data      String   // Serialized state configuration JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SavedTimetable {
  id        String   @id @default(uuid())
  name      String
  sessionId String   // to tie timetable to a user/browser session
  configId  String
  data      String   // Serialized solution schedule JSON
  createdAt DateTime @default(now())
}
