# Backend Server Port
PORT=5000

# Database URL for Prisma (SQLite for local zero-config, or PostgreSQL)
# For SQLite local development:
DATABASE_URL="file:./dev.db"
# For PostgreSQL (production/staging):
# DATABASE_URL="postgresql://user:password@localhost:5432/ibp_timetable?schema=public"

# AI Configuration (OpenRouter API Key)
# Secured on the backend. Proxy requests through /api/ai endpoints
OPENROUTER_API_KEY="your_openrouter_api_key_here"
